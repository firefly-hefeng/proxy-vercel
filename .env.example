# Vesti AI Gateway Proxy (Vercel) 环境变量示例
# 在 Vercel Dashboard → Settings → Environment Variables 中配置

# 可选：代理访问凭证
# 默认与扩展端内置值一致，开箱即用。
# 如需增强安全性，可在此覆盖为一个自定义强密码，并同步修改扩展端
# frontend/src/lib/services/llmConfig.ts 中的 DEFAULT_PROXY_SERVICE_TOKEN。
VESTI_SERVICE_TOKEN=vesti-kcq-default-d850d4dcd610a0e2e919eb610f42066faff1e1c57c0c047c

# 必填：上游 LLM 提供商 API Key
# 当前使用阿里云百炼（DashScope）
UPSTREAM_API_KEY=sk-...

# 可选：上游 OpenAI-compatible 端点
# 默认阿里云百炼；如需切换到其他兼容接口，可修改此项。
UPSTREAM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：允许的请求来源
# 生产环境建议填 chrome-extension://*（允许所有扩展来源）
# 或你的扩展具体 ID：chrome-extension://abcdefghijklmnopabcdefghijklmnop
VESTI_ALLOWED_ORIGINS=chrome-extension://*

# 可选：默认 chat 模型与备用模型
CHAT_PRIMARY_MODEL=qwen-plus
CHAT_BACKUP_MODEL=qwen-turbo

# 可选：服务端 max_tokens 上限
CHAT_MAX_TOKENS=1600

# 可选：embedding 模型
# text-embedding-v2 (1536 维) 与旧系统向量兼容；v3 为 1024 维，切换需重新向量化
EMBEDDING_MODEL=text-embedding-v2

# 可选：embedding 批量与长度限制
EMBED_BATCH_MAX=32
EMBED_TEXT_MAX_CHARS=8000

# 可选：上游超时（毫秒）
UPSTREAM_TIMEOUT_MS=60000
